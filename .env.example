# Copy to .env.local and fill in. Do not commit .env.local.

# Resend API key — used by the newsletter + contact form Vercel serverless
# functions under /api. Create one at https://resend.com/api-keys and
# scope it to "Sending access" on the sabr-labs.com domain.
RESEND_API_KEY=

# Resend Audience ID for the newsletter list. Create an Audience in the
# Resend dashboard, then copy its ID from the URL.
RESEND_AUDIENCE_ID=

# Where contact-form submissions are delivered.
CONTACT_EMAIL_TO=contact@sabr-labs.com

# The umbrella learning app. The nav links here and the /learning
# landing CTA both go to this origin.
VITE_APP_ORIGIN=https://app.sabr-labs.com

# The discussions subdomain (same app, served via middleware rewrite on
# the learning-labs project).
VITE_DISCUSSIONS_ORIGIN=https://discussions.sabr-labs.com
